# ── Database ──────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/receptionist_swarm
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=7d

# ── Voice Provider: Retell ───────────────────────────
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=

# ── SMS Provider: Twilio ─────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Search Provider: Perplexity ──────────────────────
PERPLEXITY_API_KEY=

# ── LLM Provider: OpenAI ────────────────────────────
OPENAI_API_KEY=

# ── App ──────────────────────────────────────────────
API_PORT=4000
API_BASE_URL=http://localhost:4000
CONSOLE_URL=http://localhost:3000
NODE_ENV=development
